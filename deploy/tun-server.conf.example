# AEGIS-Tunnel TUN VPN — Server
# sudo ./aegis-tunnel -C /etc/aegis/tun-server.conf -f /etc/aegis/psk.key

LISTEN_PORT = 9000
REMOTE_ADDR = 0.0.0.0:0
MODE = server
HS_TIMEOUT = 10
MAX_CONNS = 16
KEEPALIVE = 30

# TUN virtual NIC
TUN_MODE = yes
TUN_NAME = tun0
TUN_IP = 10.0.0.1
TUN_NETMASK = 255.255.255.0
# Routes to push through the tunnel
TUN_ROUTE = 10.0.0.0/24
# WAN interface for NAT (iptables MASQUERADE)
TUN_NAT_IF = eth0
