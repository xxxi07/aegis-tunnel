# AEGIS-Tunnel TUN VPN — Client
# sudo ./aegis-tunnel -C /etc/aegis/tun-client.conf -f /etc/aegis/psk.key

LISTEN_PORT = 9000
REMOTE_ADDR = server.example.com:9000
MODE = client
HS_TIMEOUT = 10
MAX_CONNS = 8
KEEPALIVE = 30

# TUN virtual NIC
TUN_MODE = yes
TUN_NAME = tun0
TUN_IP = 10.0.0.2
TUN_NETMASK = 255.255.255.0
# Route to remote network through tunnel
TUN_ROUTE = 10.0.0.0/24
